{
  "case_name": "i2c_case",
  "module": "i2c",
  "description": "Minimal I2C bus scan case for phase G asset rollout.",
  "execution": "sequential",
  "required_interfaces": {
    "i2c": {
      "required": true,
      "select": "auto"
    }
  },
  "functions": [
    {
      "name": "test_i2c_scan",
      "params": {
        "bus": "/dev/i2c-0",
        "scan_all": true
      },
      "expect": {
        "pass_policy": "all",
        "rules": [
          {
            "field": "bus_count",
            "operator": "gte",
            "value": 1,
            "message": "i2c scan must find at least one accessible bus"
          }
        ]
      },
      "timeout": 15
    }
  ]
}