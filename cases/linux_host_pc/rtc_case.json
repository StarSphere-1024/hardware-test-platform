{
  "case_name": "rtc_case",
  "module": "rtc",
  "description": "Minimal RTC validation case for phase G asset rollout.",
  "execution": "sequential",
  "required_interfaces": {
    "rtc": {
      "required": true,
      "select": "auto"
    }
  },
  "functions": [
    {
      "name": "test_rtc_read",
      "params": {
        "rtc_device": "${resolved.interfaces.rtc.primary}"
      },
      "expect": {
        "pass_policy": "all",
        "rules": [
          {
            "field": "time",
            "operator": "non_empty",
            "message": "rtc must return a readable timestamp"
          }
        ]
      },
      "timeout": 15
    }
  ]
}