{
  "case_name": "gpio_case",
  "module": "gpio",
  "board_profile": "rk3576",
  "description": "RK3576 GPIO mapping validation case.",
  "execution": "sequential",
  "required_interfaces": {
    "gpio": {
      "required": true,
      "select": "auto"
    }
  },
  "functions": [
    {
      "name": "test_gpio_mapping",
      "params": {
        "physical_pin": 7
      },
      "expect": {
        "pass_policy": "all",
        "rules": [
          {
            "field": "available",
            "operator": "eq",
            "value": true,
            "message": "gpio mapping for the requested physical pin must exist"
          }
        ]
      },
      "timeout": 10
    }
  ]
}