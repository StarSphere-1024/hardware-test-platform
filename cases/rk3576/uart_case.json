{
  "case_name": "uart_case",
  "module": "uart",
  "board_profile": "rk3576",
  "description": "RK3576 UART loopback validation case. Requires a loopback fixture on the selected serial port.",
  "execution": "sequential",
  "required_interfaces": {
    "uart": {
      "required": true,
      "select": "auto"
    }
  },
  "functions": [
    {
      "name": "test_uart_loopback",
      "params": {
        "port": "/dev/ttyS4",
        "baudrate": 115200,
        "payload": "rk3576-loopback"
      },
      "expect": {
        "pass_policy": "all",
        "rules": [
          {
            "field": "received",
            "operator": "eq",
            "value": "rk3576-loopback",
            "message": "uart must echo the RK3576 loopback payload"
          }
        ]
      },
      "retry": 0,
      "timeout": 5
    }
  ]
}